# Primary AI — Groq (fast, free tier, ~30 req/min)
# Get key: https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_...

# Fallback AI — HuggingFace (activates automatically when Groq is rate-limited)
# Get key: https://huggingface.co/settings/tokens → New token (read access is enough)
VITE_HF_API_KEY=hf_...

# Admin Chat — xAI Grok (optional, for Admin Chat panel)
# Get key: https://console.x.ai
VITE_GROK_API_KEY=xai_...
